{
  "expo": {
    "name": "Night Watch",
    "slug": "night-watch",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "通話中風UIと周囲確認のためにカメラを使用します。",
        "NSLocationWhenInUseUsageDescription": "通知ボタンを押した時だけ現在位置を送信します。"
      }
    },
    "android": {
      "permissions": ["CAMERA", "ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"]
    },
    "plugins": ["expo-camera", "expo-location"]
  }
}
